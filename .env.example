# Account Express Bookkeeping Core — Environment Configuration
# Copy this file to .env and fill in the values

# Path to the SQLite database file
DATABASE_PATH=./data/bookkeeping.db

# Server port
PORT=3000

# bcrypt cost factor (12 = ~300ms per hash — do not reduce)
BCRYPT_ROUNDS=12

# Session secret for HMAC signing (generate with: openssl rand -hex 64)
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# Application name shown in UI and system_config table
APP_NAME=Account Express Bookkeeping Core

# Initial super admin credentials (used only on first seed)
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_EMAIL=admin@localhost
SUPER_ADMIN_PASSWORD=ChangeMe@2026!

# Base de datos de TEST (separada de produccion)
TEST_DATABASE_PATH=./data/test.db
