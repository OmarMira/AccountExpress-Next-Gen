# Account Express Bookkeeping Core — Environment Configuration
# Copy this file to .env and fill in the values

# --- Database configuration ---
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Desarrollo local (PostgreSQL sin SSL):
DATABASE_URL=postgresql://accountexpress_app:YOUR_APP_PASSWORD@localhost:5432/bookkeeping
DATABASE_ADMIN_URL=postgresql://postgres:YOUR_ADMIN_PASSWORD@localhost:5432/bookkeeping

# Producción (SSL obligatorio):
# DATABASE_URL=postgresql://accountexpress_app:YOUR_APP_PASSWORD@host:5432/bookkeeping?sslmode=require
# DATABASE_ADMIN_URL=postgresql://postgres:YOUR_ADMIN_PASSWORD@host:5432/bookkeeping?sslmode=require

# --- Server and Performance ---
PORT=3000
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:5173

# --- Security and Branding ---
# Session secret (generate with: openssl rand -hex 64)
# Must be at least 16 characters
SESSION_SECRET=change-this-to-a-long-random-string-in-production
AUTO_BACKUP_SECRET=change-me-for-production

# Audit chain HMAC secret — separate from SESSION_SECRET so rotating sessions
# does not invalidate historical audit hashes.
# Generate with: openssl rand -hex 32
AUDIT_HMAC_SECRET=change-me-for-production

# Journal chain HMAC secret — separate from AUDIT_HMAC_SECRET.
# Rotating one does not affect the other subsystem.
# Generate with: openssl rand -hex 32
JOURNAL_HMAC_SECRET=change-me-for-production
APP_NAME=Account Express Bookkeeping Core

# --- Initial Seed Data ---
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_EMAIL=admin@localhost
SUPER_ADMIN_PASSWORD=ChangeMe@2026!

# --- Environment mode ---
NODE_ENV=development

# --- Backup ---
PG_DUMP_PATH=
PSQL_PATH=

# --- AI Configuration (optional) ---
# Set OLLAMA_URL to enable AI features
# If not set, AI endpoints will return "not_configured"
OLLAMA_URL=
OLLAMA_MODEL=phi3:mini
