# AccountExpress Next-Gen — Environment Configuration Example

# --- Database (PostgreSQL) ---
DATABASE_URL="postgres://user:password@localhost:5432/bookkeeping"
DATABASE_ADMIN_URL="postgres://postgres:password@localhost:5432/bookkeeping" # Optional, for migrations

# --- Server ---
PORT=3000
BCRYPT_ROUNDS=12
NODE_ENV="development" # development, production, test

# --- Security (Critical) ---
# Secrets must be at least 32 characters long.
SESSION_SECRET="your-32-char-min-session-secret-here-12345"
AUTO_BACKUP_SECRET="your-32-char-min-backup-secret-here-12345"

# --- HMAC Integrity Secrets ---
# Required ONLY if KMS_PROVIDER is "none"
AUDIT_HMAC_SECRET="your-32-char-min-audit-secret-here-12345"
JOURNAL_HMAC_SECRET="your-32-char-min-journal-secret-here-12345"

# --- KMS Configuration (Optional) ---
# Provider: aws, vault, none (default: none)
KMS_PROVIDER="none"
KMS_KEY_ID=""      # AWS ARN or Vault Key Name
KMS_REGION=""      # e.g., us-east-1 (for AWS)

# --- AI Configuration (Ollama) ---
OLLAMA_URL="http://localhost:11434"

# --- Branding ---
APP_NAME="AccountExpress"

# --- Initial Seed (Super Admin) ---
SUPER_ADMIN_USERNAME="admin"
SUPER_ADMIN_PASSWORD="secure-password-here"
SUPER_ADMIN_EMAIL="admin@example.com"
