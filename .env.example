# Account Express Bookkeeping Core — Environment Configuration
# Copy this file to .env and fill in the values

# --- Database configuration ---
# PostgreSQL 16 connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://accountexpress_app:YOUR_APP_PASSWORD@localhost:5432/bookkeeping
DATABASE_ADMIN_URL=postgresql://postgres:YOUR_ADMIN_PASSWORD@localhost:5432/bookkeeping

# --- Server and Performance ---
# Server port (default 3000)
PORT=3000

# bcrypt cost factor (12 = ~300ms per hash — do not reduce below 10)
BCRYPT_ROUNDS=12

# Allowed CORS origin — set to your frontend URL in production
# Example: https://app.tudominio.com
CORS_ORIGIN=http://localhost:5173

# --- Security and Branding ---
# Session secret for HMAC signing (generate with: openssl rand -hex 64)
# Must be at least 16 characters for security validation
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# Application name shown in UI and system_config table
APP_NAME=Account Express Bookkeeping Core

# --- Initial Seed Data ---
# Initial administrator credentials (used only on first seed/database creation)
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_EMAIL=admin@localhost
SUPER_ADMIN_PASSWORD=ChangeMe@2026!

# --- Environment mode ---
# development, production, or test
NODE_ENV=development

# Enable /auth/bypass endpoint (requires NODE_ENV=development)
ALLOW_BYPASS=false

# --- Backup ---
# Password used by the automated backup scheduler (optional)
AUTO_BACKUP_SECRET=change-me-for-production
# Absolute paths to PostgreSQL binaries (leave empty to use system PATH)
PG_DUMP_PATH=
PSQL_PATH=
