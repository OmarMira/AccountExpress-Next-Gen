{
  "name": "account-express-bookkeeping-core",
  "version": "1.0.0",
  "description": "Account Express Bookkeeping Core — Cryptographic Bookkeeping Vault",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "dev": "concurrently \"bun run --watch src/index.ts\" \"cd frontend && bun run dev\"",
    "dev:all": "concurrently \"bun run --watch src/index.ts\" \"cd frontend && bun run dev\"",
    "dev:frontend": "cd frontend && bun run dev",
    "start": "bun run --watch src/index.ts",
    "migrate": "bun run src/db/migrate.ts",
    "db:migrate": "bun run src/db/migrate.ts",
    "seed": "bun run src/db/seed/seed.ts",
    "db:seed": "bun run src/db/seed/seed.ts",
    "typecheck": "tsc --noEmit",
    "test:double-entry": "bun run scripts/test-double-entry.ts",
    "test:audit-chain": "bun run scripts/test-audit-chain.ts",
    "test:fiscal-trigger": "bun run scripts/test-fiscal-trigger.ts",
    "test:db:setup": "bun run tests/setup-db.ts",
    "test:integration": "bun run tests/run-integration.ts",
    "test:integration:verbose": "bun test tests/integration/ --timeout 15000",
    "prepare": "husky",
    "test": "bun test tests/unit/"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.28",
    "pdfkit": "^0.18.0",
    "postgres": "^3.4.8",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.20.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.11",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^11.0.0",
    "bun-types": "^1.2.5",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.20.0",
    "eslint-plugin-react-hooks": "5.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pg": "^8.20.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.23.0",
    "vitest": "^4.1.2"
  }
}
