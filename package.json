{
  "name": "account-express-bookkeeping-core",
  "version": "1.0.0",
  "description": "Account Express Bookkeeping Core — Cryptographic Bookkeeping Vault",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:all": "concurrently \"bun run src/index.ts\" \"cd frontend && bun run dev\"",
    "dev:frontend": "cd frontend && bun run dev",
    "start": "bun run src/index.ts",
    "migrate": "bun run src/db/migrate.ts",
    "db:migrate": "bun run src/db/migrate.ts",
    "seed": "bun run src/db/seed/seed.ts",
    "db:seed": "bun run src/db/seed/seed.ts",
    "typecheck": "tsc --noEmit",
    "test:double-entry": "bun run scripts/test-double-entry.ts",
    "test:audit-chain": "bun run scripts/test-audit-chain.ts",
    "test:fiscal-trigger": "bun run scripts/test-fiscal-trigger.ts"
  },
  "dependencies": {
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.4.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.28",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.11",
    "@types/uuid": "^11.0.0",
    "bun-types": "^1.2.5",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}
